generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String?
  googleId      String?  @unique
  name          String?
  avatar        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile       UserProfile?
  calendars     Calendar[]
  connectedAccounts ConnectedAccount[]
  eventTypes    EventType[]
  availabilityRules AvailabilityRule[]
  bookings      Booking[]
  notifications Notification[]
  teams         TeamMember[]
  workspaces    Workspace[]
  auditLogs     AuditLog[]

  @@map("users")
}

model UserProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  username      String?  @unique
  bio           String?
  timezone      String   @default("UTC")
  language      String   @default("en")
  theme         String   @default("light")
  publicBookingPage Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Calendar {
  id            String   @id @default(cuid())
  userId        String
  provider      String   // google, outlook, apple
  name          String
  externalId    String?
  accessToken   String?
  refreshToken  String?
  expiresAt     DateTime?
  isPrimary     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  events        CalendarEvent[]

  @@map("calendars")
}

model ConnectedAccount {
  id            String   @id @default(cuid())
  userId        String
  provider      String   // google, outlook, zoom, teams, stripe
  providerAccountId String
  accessToken   String?
  refreshToken  String?
  expiresAt     DateTime?
  scope         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("connected_accounts")
}

model CalendarEvent {
  id            String   @id @default(cuid())
  calendarId    String
  externalId    String?
  title         String
  description   String?
  startTime     DateTime
  endTime       DateTime
  isBusy        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  calendar      Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@map("calendar_events")
}

model EventType {
  id            String   @id @default(cuid())
  userId        String
  title         String
  slug          String
  description   String?
  duration      Int      // minutes
  location      String?  // meet, zoom, phone, in-person
  color         String   @default("#3b82f6")
  isActive      Boolean  @default(true)
  bufferBefore  Int      @default(0)
  bufferAfter   Int      @default(0)
  minimumNotice Int      @default(0) // hours
  maximumBookingsPerDay Int? // Phase 2
  requiresConfirmation Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings      Booking[]
  questions     BookingQuestion[]

  @@unique([userId, slug])
  @@map("event_types")
}

model AvailabilityRule {
  id            String   @id @default(cuid())
  userId        String
  eventTypeId   String?  // optional: if null, applies globally
  dayOfWeek     Int      // 0-6 (Sunday-Saturday)
  startTime     String   // HH:mm
  endTime       String   // HH:mm
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("availability_rules")
}

model Booking {
  id            String   @id @default(cuid())
  userId        String
  eventTypeId   String
  guestName     String
  guestEmail    String
  guestPhone    String?
  guestNotes    String?
  startTime     DateTime
  endTime       DateTime
  status        String   @default("confirmed") // confirmed, cancelled, rescheduled, no-show
  location      String?
  meetingLink   String?
  timezone      String   @default("UTC")
  cancelledAt   DateTime?
  cancellationReason String?
  rescheduledFromId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType     EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  answers       BookingAnswer[]
  notifications Notification[]
  payment       Payment?

  @@map("bookings")
}

model BookingQuestion {
  id            String   @id @default(cuid())
  eventTypeId   String
  label         String
  type          String   @default("text") // text, textarea, select, phone, email, file
  required      Boolean  @default(false)
  options       String  // JSON array for select type
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  eventType     EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  answers       BookingAnswer[]

  @@map("booking_questions")
}

model BookingAnswer {
  id            String   @id @default(cuid())
  bookingId     String
  questionId    String
  answer        String
  createdAt     DateTime @default(now())

  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  question      BookingQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("booking_answers")
}

model Team {
  id            String   @id @default(cuid())
  workspaceId   String
  name          String
  slug          String
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members       TeamMember[]

  @@map("teams")
}

model TeamMember {
  id            String   @id @default(cuid())
  teamId        String
  userId        String
  role          String   @default("member") // admin, member
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  team          Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

model Workspace {
  id            String   @id @default(cuid())
  ownerId       String
  name          String
  slug          String   @unique
  description   String?
  plan          String   @default("free") // free, pro, enterprise
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  teams         Team[]

  @@map("workspaces")
}

model Notification {
  id            String   @id @default(cuid())
  userId        String
  bookingId     String?
  type          String   // email, sms, whatsapp, push
  channel       String   // confirmation, cancellation, reminder, reschedule
  status        String   @default("pending") // pending, sent, failed
  scheduledAt   DateTime?
  sentAt        DateTime?
  content       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking       Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@map("notifications")
}

model Payment {
  id            String   @id @default(cuid())
  bookingId     String   @unique
  amount        Decimal
  currency      String   @default("USD")
  provider      String   // stripe, razorpay, paypal
  status        String   @default("pending") // pending, completed, refunded, failed
  transactionId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Webhook {
  id            String   @id @default(cuid())
  userId        String
  url           String
  secret        String
  events        String  // JSON array: booking.created, booking.cancelled, etc.
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("webhooks")
}

model Integration {
  id            String   @id @default(cuid())
  userId        String
  type          String   // zapier, slack, crm
  config        Json?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("integrations")
}

model AuditLog {
  id            String   @id @default(cuid())
  userId        String
  action        String
  entityType    String   // user, booking, event_type, etc.
  entityId      String?
  metadata      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model PasswordResetToken {
  id            String   @id @default(cuid())
  userId        String
  token         String   @unique
  expiresAt     DateTime
  used          Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@map("password_reset_tokens")
}

model DateOverride {
  id            String   @id @default(cuid())
  userId        String
  date          String   // YYYY-MM-DD
  startTime     String   // HH:mm
  endTime       String   // HH:mm
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, date])
  @@map("date_overrides")
}
